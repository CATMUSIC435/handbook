    {
      "id": 1,
      "name": "Hồ bơi vô cực",
      "description": "Hồ bơi tràn viền chuẩn resort 5 sao trên tầng thượng, mang đến tầm nhìn toàn cảnh thành phố lung linh về đêm. Được trang bị hệ thống lọc nước ion hiện đại và khu vực bơi riêng an toàn cho trẻ em.",
      "distance": "Tầng 5 - Block A",
      "hours": "06:00 - 22:00",
      "image": "/assets/images/ho-boi-fenica.webp"
    },
    {
      "id": 2,
      "name": "Khu BBQ ngoài trời",
      "description": "Không gian tổ chức tiệc nướng BBQ thoáng đãng, lý tưởng cho những buổi tụ họp gia đình và bạn bè cuối tuần. Khu vực được bố trí sẵn bếp nướng, bàn ghế và bồn rửa tiện lợi.",
      "distance": "Công viên nội khu",
      "hours": "08:00 - 22:00",
      "image": "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
    },
    {
      "id": 3,
      "name": "Phòng Gym 360°",
      "description": "Phòng tập thể hình hiện đại với đầy đủ trang thiết bị tiêu chuẩn quốc tế từ Technogym. Đặc biệt thiết kế kính cường lực trong suốt bao quanh giúp bạn vừa tập luyện vừa ngắm nhìn cảnh quan xanh mát.",
      "distance": "Tầng 3 - Block B",
      "hours": "05:00 - 23:00",
